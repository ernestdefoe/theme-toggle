{
  "name": "ernestdefoe/theme-toggle",
  "description": "Adds a day/night/system toggle button to the Flarum 2 header. Works with any theme via the native data-theme attribute.",
  "keywords": ["flarum", "flarum-extension", "theme", "dark-mode", "light-mode", "toggle"],
  "type": "flarum-extension",
  "license": "MIT",
  "authors": [
    {
      "name": "ernestdefoe",
      "email": "ernestdefoe@gmail.com"
    }
  ],
  "homepage": "https://github.com/ernestdefoe/theme-toggle",
  "support": {
    "issues": "https://github.com/ernestdefoe/theme-toggle/issues",
    "source": "https://github.com/ernestdefoe/theme-toggle"
  },
  "require": {
    "php": "^8.3",
    "flarum/core": "^2.0"
  },
  "extra": {
    "flarum-extension": {
      "title": "Theme Toggle",
      "category": "feature",
      "icon": {
        "name": "fas fa-moon",
        "backgroundColor": "#1f2937",
        "color": "#fbbf24"
      }
    }
  }
}
